# Sample environment file for the OuroborosFS systemd units.
# Install at /etc/default/ouroboros (Debian/Ubuntu convention) or wherever
# the EnvironmentFile= directive in the unit points.
#
# All values shown are examples; replace before deploying.

# Pre-shared key for the wire-protocol AUTH handshake AND the HTTP
# Bearer token. Generate with:
#   openssl rand -hex 32
OUROBOROS_AUTH_TOKEN=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Tracing log filter. See https://docs.rs/tracing-subscriber for syntax.
RUST_LOG=info,ouroboros_fs=info
